{
  "manifest_version": 3,
  "name": "BridgeGPT",
  "description": "Bridge ChatGPT (web) to your apps via a self-hosted OpenAI-compatible relay.",
  "action": {
    "default_popup": "src/pages/popup/index.html",
    "default_icon": {
      "32": "icon-32.png"
    }
  },
  "icons": {
    "128": "icon-128.png"
  },
  "host_permissions": [
        "http://*/*",
        "https://*/*",
        "<all_urls>"],

  "permissions": ["alarms", "storage", "tabs"],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*"
      ],
      "js": [
        "src/pages/content/index.tsx"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icon-128.png",
        "icon-32.png"
      ],
      "matches": []
    },
    {
      "resources": ["chatgpt-page.js"],
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ]
    },
    {
      "resources": ["gemini-page.js"],
      "matches": ["https://gemini.google.com/*"]
    },
    {
      "resources": ["src/pages/settings/index.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
