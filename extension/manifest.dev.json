{
  "action": {
    "default_icon": {
      "32": "dev-icon-32.png"
    },
    "default_popup": "src/pages/popup/index.html"
  },
  "icons": {
    "128": "dev-icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "dev-icon-128.png",
        "dev-icon-32.png"
      ],
      "matches": []
    },
            {
      "resources": ["loader.js"],
      "matches": ["https://*.chatgpt.com/*", "https://chat.openai.com/*"]
    },
    {
      "resources": ["gemini-page.js"],
      "matches": ["https://gemini.google.com/*"]
    }
  ]
}
